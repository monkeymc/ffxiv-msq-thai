---
import '../styles/global.css';

const pluginInfo = {
  name: 'MSQThai',
  internalName: 'ffxiv-msq-thai',
  author: 'monkeymc',
  version: '1.2.0.0',
  apiLevel: '15',
  compatibility: 'FFXIV Dawntrail 7.x (any)',
  command: '/th',
  downloadUrl: 'https://raw.githubusercontent.com/monkeymc/ffxiv-msq-thai/main/Release/latest.zip'
};

const changelog = [
  {
    version: 'v1.2.0.0',
    date: '2026-05-25',
    changes: [
      'Renamed commands: /msqth → /th, added /thf <size> to set font size (10–60) in-game.',
      'In-game debug channel feedback: /th prints Turn → ON/OFF, /thf prints Font Size → X px.',
      'Plugin icon added (gold TH emblem) — visible in Dalamud plugin browser and installer.',
      'Default font size increased from 18 px to 36 px for improved readability.',
      'Fallback overlay position raised to 90% screen height (was 82%).',
      'Cutscene overlay minimum height reduced from 100 px to 50 px.',
      'Cutscene anchor button repositioned above the overlay panel (was inside top-right corner).',
    ]
  },
  {
    version: 'v1.1.0.0',
    date: '2026-05-24',
    changes: [
      'Critical Performance Hotfix - Eliminate Game Stuttering/Shuttering on NPC Talk Addon.',
      'Asynchronous Fuzzy Matching: Offloaded Levenshtein distance calculations to background ThreadPool tasks.',
      'Thread-Safe Caching: Upgraded fuzzy match cache to ConcurrentDictionary to support async concurrent lookups.',
      'Guaranteed 0ms UI Thread Overhead: Bypassed heavy computations on the rendering thread entirely.'
    ]
  },
  {
    version: 'v1.0.0.0',
    date: '2026-05-24',
    changes: [
      'Initial release of the Thai MSQ Translation Plugin.',
      'Integrated dialogue dictionary covering ARR and Dawntrail quests.',
      'Dynamic font loading (TH Sarabun New) for clean Thai text rendering in ImGui overlay.',
      'Anchor widgets to drag and position the overlay over the default game talk dialog.',
      'Toggle overlay visibility using `/th` command.',
    ]
  },
  {
    version: 'v0.9.0.0 (Beta)',
    date: '2026-05-15',
    changes: [
      'First closed testing build.',
      'Basic TalkHook dialogue interceptor.',
      'Implemented local word-segmentation for proper Thai word wrapping in ImGui.'
    ]
  }
];

const builds = [
  {
    label: 'Debug',
    description: 'Builds and deploys directly to XIVLauncher devPlugins folder.',
    command: 'wsl -e bash -c "cd /home/chatja/ffxiv-msq-thai/plogon/ffxiv-msq-thai/ffxiv-msq-thai && dotnet build ffxiv-msq-thai.csproj -c Debug -o /mnt/c/Users/mcdai/AppData/Roaming/XIVLauncher/devPlugins/ffxiv-msq-thai"',
    output: 'C:\\Users\\mcdai\\AppData\\Roaming\\XIVLauncher\\devPlugins\\ffxiv-msq-thai\\'
  },
  {
    label: 'Release',
    description: 'Builds a release zip via DalamudPackager. Must be run from inside WSL.',
    command: 'wsl -e bash -c "cd /home/chatja/ffxiv-msq-thai/plogon/ffxiv-msq-thai && dotnet build ffxiv-msq-thai.sln -c Release"',
    output: 'plogon/ffxiv-msq-thai/ffxiv-msq-thai/bin/Release/'
  }
];

const issues = [
  {
    id: '#1',
    title: 'Thai text wrapping & clipping in some screen sizes',
    status: 'fixed',
    statusText: 'Fixed',
    notes: 'Implemented ThaiWordSegmenter dictionary-based word wrapping.'
  },
  {
    id: '#2',
    title: 'Option to adjust font size and opacity in config UI',
    status: 'fixed',
    statusText: 'Fixed',
    notes: 'Config UI settings added to anchor widget config window.'
  },
  {
    id: '#3',
    title: 'Cutscene dialogue matching',
    status: 'fixed',
    statusText: 'Fixed',
    notes: 'Successfully matched and display translations on CutSceneSubtitle and CutsceneDialogue addons.'
  },
  {
    id: '#4',
    title: 'Critical Performance Hotfix - Eliminate Game Stuttering/Shuttering on NPC Talk Addon',
    status: 'fixed',
    statusText: 'Fixed',
    notes: 'Implemented Asynchronous Fuzzy Matching using background Task.Run and ConcurrentDictionary cache, ensuring 0ms main thread impact.'
  }
];
---

<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dalamud Plugin — MSQ Thai</title>
  </head>
  <body>
    <main class="plogon">
      <header class="plogon-header">
        <a href="/" class="back-link">&#8592; BACK</a>
        <h1>MSQ Thai — Plogon</h1>
        <p class="subtitle">Dalamud plugin versioning, compatibility details, and changelog tracker</p>
      </header>

      <section class="version-section">
        <h2>Plugin Version & Compatibility</h2>
        <div class="version-grid">
          <div class="version-card">
            <h3>Plugin Name</h3>
            <span class="version-value">{pluginInfo.name}</span>
            <span class="version-desc">Internal ID: {pluginInfo.internalName}</span>
          </div>
          <div class="version-card">
            <h3>Latest Version</h3>
            <span class="version-value">v{pluginInfo.version}</span>
            <span class="version-desc">Dalamud API Level {pluginInfo.apiLevel}</span>
          </div>
          <div class="version-card">
            <h3>Game Compatibility</h3>
            <span class="version-value">7.x</span>
            <span class="version-desc">{pluginInfo.compatibility}</span>
          </div>
          <div class="version-card">
            <h3>Console Command</h3>
            <span class="version-value">{pluginInfo.command}</span>
            <span class="version-desc">Toggles translation overlay overlay</span>
          </div>
        </div>

        <div style="margin-bottom: 3rem; text-align: center;">
          <a href={pluginInfo.downloadUrl} class="download-btn" target="_blank" rel="noopener">
            <span>&#128229; Download Latest ZIP</span>
          </a>
        </div>
      </section>

      <section class="build-section">
        <h2>Build Scripts</h2>
        <div class="build-grid">
          {builds.map((b) => (
            <div class="build-card">
              <div class="build-header">
                <span class={`build-badge ${b.label.toLowerCase()}`}>{b.label}</span>
                <span class="build-desc">{b.description}</span>
              </div>
              <pre class="build-cmd"><code>{b.command}</code></pre>
              <div class="build-output">
                <span class="build-output-label">Output →</span>
                <code>{b.output}</code>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="changelog-section">
        <h2>Changelog</h2>
        <div class="timeline">
          {changelog.map((item) => (
            <div class="timeline-item">
              <div class="timeline-badge"></div>
              <div class="timeline-header">
                <span class="timeline-version">{item.version}</span>
                <span class="timeline-date">{item.date}</span>
              </div>
              <div class="timeline-body">
                <ul>
                  {item.changes.map((change) => (
                    <li>{change}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="issues-section">
        <h2>Issue Progress & Roadmap</h2>
        <table class="quest-table">
          <thead>
            <tr>
              <th class="col-num" style="width: 80px;">Issue ID</th>
              <th class="col-title">Description</th>
              <th class="col-level" style="width: 150px; text-align: center;">Status</th>
              <th style="color: var(--text-secondary);">Notes</th>
            </tr>
          </thead>
          <tbody>
            {issues.map((issue) => (
              <tr>
                <td class="col-num" style="font-family: 'JetBrains Mono', monospace;">{issue.id}</td>
                <td class="col-title" style="color: var(--text);">{issue.title}</td>
                <td class="col-level" style="text-align: center;">
                  <span class={`status-badge ${issue.status}`}>{issue.statusText}</span>
                </td>
                <td style="color: var(--text-secondary); font-size: 0.9rem;">{issue.notes}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    </main>
  </body>
</html>

<style>
  .build-section {
    margin-bottom: 3rem;
  }

  .build-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .build-card {
    background: var(--surface, #1a1a1a);
    border: 1px solid var(--border, #333);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
  }

  .build-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .build-badge {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .build-badge.debug {
    background: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .build-badge.release {
    background: rgba(34, 197, 94, 0.12);
    color: #4ade80;
    border: 1px solid rgba(34, 197, 94, 0.25);
  }

  .build-desc {
    color: var(--text-secondary, #888);
    font-size: 0.9rem;
  }

  .build-cmd {
    background: var(--bg, #111);
    border: 1px solid var(--border, #2a2a2a);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    margin: 0 0 0.75rem;
    overflow-x: auto;
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .build-cmd code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    color: #e2c97e;
    white-space: pre;
  }

  .build-output {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
  }

  .build-output-label {
    color: var(--text-secondary, #888);
    white-space: nowrap;
  }

  .build-output code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    color: var(--text-secondary, #aaa);
  }
</style>
