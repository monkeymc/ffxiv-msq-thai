---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MSQ Thai — Spec</title>
  </head>
  <body>
    <main class="index">
      <header class="index-hero">
        <h1>FFXIV<br/>MSQ Thai</h1>
        <p>แปลและอ่านบทสนทนา MSQ เป็นภาษาไทย</p>
      </header>

      <nav class="nav-cards">
        <a href="/scenario/" class="nav-card">
          <div class="nav-card-icon">&#9997;&#65039;</div>
          <div class="nav-card-body">
            <h2>Scenario</h2>
            <p>แผนงานและสถานะการพัฒนา</p>
          </div>
        </a>

        <a href="/dawntrail/" class="nav-card">
          <div class="nav-card-icon">&#127794;</div>
          <div class="nav-card-body">
            <h2>Dawntrail</h2>
            <p>รายการเควส Post-Dawntrail 39 ข้อ</p>
          </div>
        </a>

        <a href="/plogon/" class="nav-card">
          <div class="nav-card-icon">&#128640;</div>
          <div class="nav-card-body">
            <h2>Plogon</h2>
            <p>Dalamud Plugin, Changelog, และสถานะบั๊ก</p>
          </div>
        </a>

        <a href="https://github.com/monkeymc/ffxiv-msq-thai" class="nav-card nav-card--github" target="_blank" rel="noopener">
          <div class="nav-card-icon">&#128008;</div>
          <div class="nav-card-body">
            <h2>GitHub</h2>
            <p>Source code, releases, และ issue tracker</p>
          </div>
        </a>
      </nav>

      <section class="stats">
        <div class="stat">
          <span class="stat-number">214</span>
          <span class="stat-label">ARR Quests</span>
        </div>
        <div class="stat">
          <span class="stat-number">39</span>
          <span class="stat-label">Dawntrail</span>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  .nav-card--github:hover {
    border-color: #8b949e;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3), 0 0 40px rgba(139, 148, 158, 0.2);
  }
  .nav-card--github::before {
    background: radial-gradient(ellipse at top left, rgba(139, 148, 158, 0.08) 0%, transparent 70%);
  }
</style>
