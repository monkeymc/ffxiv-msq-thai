---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — FFXIV MSQ ภาษาไทย</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;700&display=swap" />
  </head>
  <body>
    <header>
      <nav>
        <a href={`${base}/`} class="brand">FFXIV MSQ Thai</a>
        <div class="nav-links">
          <a href={`${base}/`}>หน้าหลัก</a>
          <a href={`${base}/quests/`}>สารบัญ</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        ข้อมูลจาก <a href="https://ffxiv.consolegameswiki.com" target="_blank" rel="noopener">FFXIV Console Games Wiki</a>
        &nbsp;·&nbsp; ไม่ใช่เนื้อหาทางการของ Square Enix
      </p>
    </footer>
  </body>
</html>
