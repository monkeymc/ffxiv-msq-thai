---
import '../styles/global.css';

interface Props {
  title: string;
  active?: 'home' | 'toc' | 'about';
}
const { title, active } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — FFXIV MSQ ภาษาไทย</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Sarabun:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" />
    <script is:inline>
      // Theme: apply ASAP to avoid flash. Defaults to system preference.
      (function () {
        try {
          var saved = localStorage.getItem('ffxiv-msq-th:theme');
          var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = saved || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="site">
      <nav>
        <a class="brand" href={`${base}/`}>
          <span class="brand-text">
            <span class="en">FFXIV MSQ THAI</span>
            <span class="th">บันทึกการผจญภัย</span>
          </span>
        </a>
        <div class="nav-links">
          <a href={`${base}/`} class={active === 'home' ? 'active' : ''}>หน้าหลัก</a>
          <a href={`${base}/quests/`} class={active === 'toc' ? 'active' : ''}>สารบัญ</a>
          <button class="theme-toggle" id="themeToggle" aria-label="สลับโหมดสว่าง/มืด" title="สลับโหมด">
            <svg class="icon-sun"  viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path></svg>
            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"></path></svg>
          </button>
        </div>
      </nav>
    </header>
    <slot name="below-header" />
    <main>
      <slot />
    </main>
    <footer class="site">
      <p>
        ข้อมูล quest จาก <a href="https://ffxiv.consolegameswiki.com" target="_blank" rel="noopener">FFXIV Console Games Wiki</a>
        &nbsp;·&nbsp; โครงการแฟนเมด ไม่เกี่ยวข้องกับ Square Enix
      </p>
    </footer>

    <script is:inline>
      (function () {
        var btn = document.getElementById('themeToggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          var cur = document.documentElement.getAttribute('data-theme') || 'light';
          var next = cur === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('ffxiv-msq-th:theme', next); } catch (e) {}
        });
      })();
    </script>
  </body>
</html>
