---
import '../styles/global.css';

interface Props {
  title: string;
  active?: 'home' | 'toc' | 'about';
}
const { title, active } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — FFXIV MSQ ภาษาไทย</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Sarabun:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" />
  </head>
  <body>
    <header class="site">
      <nav>
        <a class="brand" href={`${base}/`}>
          <span class="brand-text">
            <span class="en">FFXIV MSQ THAI</span>
            <span class="th">บันทึกการผจญภัย</span>
          </span>
        </a>
        <div class="nav-links">
          <a href={`${base}/`} class={active === 'home' ? 'active' : ''}>หน้าหลัก</a>
          <a href={`${base}/quests/`} class={active === 'toc' ? 'active' : ''}>สารบัญ</a>
        </div>
      </nav>
    </header>
    <slot name="below-header" />
    <main>
      <slot />
    </main>
    <footer class="site">
      <p>
        ข้อมูล quest จาก <a href="https://ffxiv.consolegameswiki.com" target="_blank" rel="noopener">FFXIV Console Games Wiki</a>
        &nbsp;·&nbsp; โครงการแฟนเมด ไม่เกี่ยวข้องกับ Square Enix
      </p>
    </footer>
  </body>
</html>
